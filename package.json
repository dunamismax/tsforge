{
  "name": "tsforge",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*",
    "scripts/*"
  ],
  "engines": {
    "bun": ">=1.3.10"
  },
  "scripts": {
    "dev": "bun run dev:web",
    "dev:web": "bun run --filter @tsforge/web dev",
    "build": "bun run --workspaces --if-present build",
    "typecheck": "bun run --workspaces --if-present typecheck",
    "test": "bun run --workspaces --if-present test",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check . && bun run typecheck",
    "script:email-template": "bun run --filter @tsforge/email-template-converter start",
    "script:batch-grade": "bun run --filter @tsforge/batch-grade start",
    "script:signal-fit": "bun run --filter @tsforge/signal-fit start",
    "db:generate": "bun run --filter @tsforge/db db:generate",
    "db:migrate": "bun run --filter @tsforge/db db:migrate"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/node": "^24.5.2",
    "bun-types": "1.3.10",
    "typescript": "^5.9.2",
    "vitest": "4.0.18"
  },
  "trustedDependencies": [
    "esbuild"
  ]
}
